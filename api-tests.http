### API tests for NotaFiscal Online
# Usage:
# 1) Run the "Login" request and copy the returned token value (data.token).
# 2) Set the value of the `token` variable below (replace the empty value) or use your REST client environment feature.
# 3) Run the other requests which use the Authorization header.

# Base URL (ajustado para porta 9000)
@baseUrl = http://localhost:9000
@token = 

### Login
POST {{baseUrl}}/v1/auth/login
Content-Type: application/json

{
  "username": "portal",
  "password": "portal3694"
}

### Health (public)
GET {{baseUrl}}/health
Accept: application/json


### Swagger JSON (docs)
GET {{baseUrl}}/swagger/doc/json
Accept: application/json


### Get certificate status (replace CNPJ if needed)
GET {{baseUrl}}/v1/certificados/00073365000146
Accept: application/json
Authorization: Bearer {{token}}


### Upload certificate (PFX) - replace certificado (base64) and senha
POST {{baseUrl}}/v1/certificados/upload
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "cnpj": "00073365000146",
  "certificado": "",
  "senha": "zacarias200968"
}


### Example: get SEFAZ status (requires token)
GET {{baseUrl}}/v1/sefaz/status?uf=MS&modelo=55
Accept: application/json
Authorization: Bearer {{token}}


### Emit NFC-e (example payload)
POST {{baseUrl}}/v1/nfce
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "cnpj_emitente": "00073365000146",
  "natureza_operacao": "VENDA A CONSUMIDOR",
  "serie": 1,
  "ambiente": 2,
  "emit_razao_social": "AUTO_PECAS_RIO_DOURADOS",
  "emit_nome_fantasia": "AUTO PECAS RIO",
  "emit_ie": "123456789",
  "emit_crt": 3,
  "emit_endereco": {
    "logradouro": "Rua Exemplo",
    "numero": "100",
    "bairro": "Centro",
    "municipio": "Sao Paulo",
    "uf": "SP",
    "cep": "01001000",
    "codigo_municipio": 3550308
  },
  "cpf_cliente": "",
  "nome_cliente": "",
  "itens": [
    {
      "codigo": "001",
      "descricao": "Produto A",
      "ean": "SEM GTIN",
      "ncm": "87082900",
      "cfop": "5102",
      "unidade": "UN",
      "quantidade": 1,
      "valor_unitario": 10.0,
      "valor_total": 10.0,
      "cest": "",
      "cst_icms": "102",
      "aliq_icms": 0,
      "cst_pis": "07",
      "aliq_pis": 0,
      "cst_cofins": "07",
      "aliq_cofins": 0,
      "desconto": 0
    }
  ],
  "pagamentos": [
    {
      "forma": 1,
      "valor": 10.0
    }
  ]
}

